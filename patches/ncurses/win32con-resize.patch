# Make console resizes actually re-layout the application (ncurses win32 driver).
#
# Windows has no SIGWINCH, and three things were missing: the driver never set
# ENABLE_WINDOW_INPUT (so no WINDOW_BUFFER_SIZE_EVENT was queued), twait consumed
# any such event, and -- because this ncurses is configured without USE_SIZECHANGE
# (no TIOCGWINSZ on the cross-build) -- its automatic-resize machinery
# (SCREEN._resize, the active half of _nc_update_screensize) is compiled out, so
# nothing ever updated LINES/COLS. Delivering KEY_RESIZE alone therefore made nano
# redraw at the old size (flicker) without ever resizing.
#
# Fix, all in ncurses/tinfo/lib_win32con.c:
#   * _nc_console_setmode: add ENABLE_WINDOW_INPUT so resize events are queued.
#   * _nc_console_twait: surface WINDOW_BUFFER_SIZE_EVENT as input (TW_INPUT).
#   * _nc_console_read: on such an event, re-query the console (_nc_console_get_SBI)
#     and, only when the visible size actually changed, call resize_term() to
#     update LINES/COLS and stdscr, then return KEY_RESIZE. nano turns that into
#     its resize trigger (win32-resize.patch). No-op events -- including the
#     buffer-size events our own resize emits -- are swallowed, so the app neither
#     flickers nor feeds back endlessly.
#
# NOTE: the legacy console (pre-Win10) decouples window from screen buffer, so a
# window-only drag emits no event there; this covers the modern console and any
# real buffer-size change.

diff --git a/ncurses/tinfo/lib_win32con.c b/ncurses/tinfo/lib_win32con.c
index 3a0f466..bd06c39 100644
--- a/ncurses/tinfo/lib_win32con.c
+++ b/ncurses/tinfo/lib_win32con.c
@@ -256,7 +256,7 @@ _nc_console_setmode(HANDLE hdl, const TTY * arg)
 #endif
 	T(("lib_win32con:_nc_console_setmode %s", _nc_trace_ttymode(arg)));
 	if (hdl == WINCONSOLE.inp) {
-	    dwFlag = arg->dwFlagIn | ENABLE_MOUSE_INPUT | VT_FLAG_IN;
+	    dwFlag = arg->dwFlagIn | ENABLE_MOUSE_INPUT | ENABLE_WINDOW_INPUT | VT_FLAG_IN;
 	    TRCTTYIN(dwFlag);
 	    SetConsoleMode(hdl, dwFlag);
 
@@ -270,7 +270,7 @@ _nc_console_setmode(HANDLE hdl, const TTY * arg)
 	    SetConsoleMode(hdl, dwFlag);
 
 	    alt = WINCONSOLE.inp;
-	    dwFlag = arg->dwFlagIn | ENABLE_MOUSE_INPUT;
+	    dwFlag = arg->dwFlagIn | ENABLE_MOUSE_INPUT | ENABLE_WINDOW_INPUT;
 	    TRCTTYIN(dwFlag);
 	    SetConsoleMode(alt, dwFlag);
 	    T(("effective mode set %s", _nc_trace_ttymode(&TRCTTY)));
@@ -949,6 +949,15 @@ _nc_console_twait(
 				goto end;
 			    }
 			    continue;
+			case WINDOW_BUFFER_SIZE_EVENT:
+			    /* Surface console resizes as input so the following read
+			     * returns KEY_RESIZE; do not consume the event here. */
+			    if (mode & TW_INPUT) {
+				code = TW_INPUT;
+				goto end;
+			    }
+			    CONSUME();
+			    continue;
 			    /* e.g., FOCUS_EVENT */
 			default:
 			    T(("twait:event Type %d", inp_rec.EventType));
@@ -1073,6 +1082,28 @@ _nc_console_read(
 		    *buf = KEY_MOUSE;
 		    break;
 		}
+	    } else if (inp_rec.EventType == WINDOW_BUFFER_SIZE_EVENT) {
+		/* The console was resized.  Base Windows has no SIGWINCH, and this
+		 * ncurses is built without USE_SIZECHANGE, so its automatic-resize
+		 * machinery is compiled out -- the driver must do it.  Re-query the
+		 * console and, only when the visible size actually changed, call
+		 * resize_term() to update LINES/COLS (and stdscr), then report
+		 * KEY_RESIZE.  No-op events are swallowed -- including the buffer-
+		 * size events our own resize emits -- so the app neither flickers
+		 * nor feeds back endlessly. */
+		int old_l = 0, old_c = 0, new_l = 0, new_c = 0;
+
+		_nc_console_size(&old_l, &old_c);	/* from the cached SBI */
+		_nc_console_get_SBI();			/* re-query the console */
+		_nc_console_size(&new_l, &new_c);	/* from the refreshed SBI */
+
+		if (new_l > 0 && new_c > 0 &&
+		    (new_l != old_l || new_c != old_c)) {
+		    resize_term(new_l, new_c);
+		    *buf = KEY_RESIZE;
+		    break;
+		}
+		continue;
 	    }
 	    continue;
 	}
