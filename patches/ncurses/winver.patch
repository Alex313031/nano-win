Build the driver targeting WINVER=0x0500 (Windows 2000) instead of 0x0501 (Windows XP).

diff --git a/configure b/configure
index 48ad381..4e833aa 100755
--- a/configure
+++ b/configure
@@ -19088,7 +19088,7 @@ case "$cf_cv_system_name" in
 	if test "x$with_named_pipes" = xyes ; then
 		CPPFLAGS="$CPPFLAGS -DWINVER=0x0600 -DWIN32_LEAN_AND_MEAN"
 	else
-		CPPFLAGS="$CPPFLAGS -DWINVER=0x0501 -DWIN32_LEAN_AND_MEAN"
+		CPPFLAGS="$CPPFLAGS -DWINVER=0x0500 -D_WIN32_WINNT=0x0500 -DWIN32_LEAN_AND_MEAN"
 	fi
 
 echo "$as_me:19094: checking if ssp library is needed" >&5
diff --git a/configure.in b/configure.in
index ad79dc9..cd17c34 100644
--- a/configure.in
+++ b/configure.in
@@ -1743,7 +1743,7 @@ case "$cf_cv_system_name" in
 	if test "x$with_named_pipes" = xyes ; then
 		CPPFLAGS="$CPPFLAGS -DWINVER=0x0600 -DWIN32_LEAN_AND_MEAN"
 	else
-		CPPFLAGS="$CPPFLAGS -DWINVER=0x0501 -DWIN32_LEAN_AND_MEAN"
+		CPPFLAGS="$CPPFLAGS -DWINVER=0x0500 -D_WIN32_WINNT=0x0500 -DWIN32_LEAN_AND_MEAN"
 	fi
 	CF_CHECK_LIBSSP
 	;;
diff --git a/include/nc_win32.h.in b/include/nc_win32.h.in
index 271e40a..65e150d 100644
--- a/include/nc_win32.h.in
+++ b/include/nc_win32.h.in
@@ -72,11 +72,11 @@
 #else /* !USE_NAMED_PIPES */
 
 #ifdef WINVER
-#  if WINVER < 0x0501
-#    error WINVER must at least be 0x0501
+#  if WINVER < 0x0500
+#    error WINVER must at least be 0x0500 (Windows 2000)
 #  endif
 #else
-#  define WINVER 0x0501
+#  define WINVER 0x0500 /* Default to Windows 2000 */
 #endif
 
 #include <windows.h>
