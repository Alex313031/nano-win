Extra tweaks for the Windows nano build:
 - Colorful compiled-in interface defaults, no rc files (src/color.c).
 - Line numbers shown by default; unset linenumbers to disable (src/nano.c).
 - New files default to DOS/CRLF line endings (src/files.c).
 - A .nanorc next to nano.exe is used exclusively, overriding all other
   locations, so nano can run as a portable app (src/rcfile.c).
 - Richer C/C++ syntax highlighting (syntax/c.nanorc).
 - Compile in a Windows resource: icon + version info via windres
   (src/Makefile.am; nano.rc + nano.ico copied into src/ by the build).

diff --git a/src/Makefile.am b/src/Makefile.am
index a678e29..3bb7cff 100644
--- a/src/Makefile.am
+++ b/src/Makefile.am
@@ -1,7 +1,7 @@
 AM_CPPFLAGS = -DLOCALEDIR=\"$(localedir)\" -DSYSCONFDIR=\"$(sysconfdir)\" \
 	-I$(top_builddir)/lib -I$(top_srcdir)/lib
 
-CLEANFILES = revision.h
+CLEANFILES = revision.h nano_rc.$(OBJEXT)
 
 if BUILDING_FROM_GIT
 SOMETHING = "REVISION \"`git describe --tags 2>/dev/null`\""
@@ -43,7 +43,13 @@ nano_SOURCES = \
 		winio.c
 
 nano_LDADD = $(top_builddir)/lib/libgnu.a @LIBINTL@ \
-		$(GETRANDOM_LIB) $(CLOCK_TIME_LIB) $(LIBTHREAD)
+		$(GETRANDOM_LIB) $(CLOCK_TIME_LIB) $(LIBTHREAD) \
+		nano_rc.$(OBJEXT)
+
+# Windows resource: application icon + version info, compiled with windres.
+# nano.rc and nano.ico are copied into src/ by build_nano.sh before the build.
+nano_rc.$(OBJEXT): $(srcdir)/nano.rc $(srcdir)/nano.ico
+	@host_alias@-windres -I$(srcdir) -O coff -i $(srcdir)/nano.rc -o $@
 
 install-exec-hook:
 	cd $(DESTDIR)$(bindir) && rm -f rnano && $(LN_S) nano rnano
diff --git a/src/color.c b/src/color.c
index 5e38140..0b67606 100644
--- a/src/color.c
+++ b/src/color.c
@@ -54,6 +54,37 @@ void set_interface_colorpairs(void)
 			init_pair(index + 1, combo->fg, combo->bg);
 			interface_color_pair[index] = COLOR_PAIR(index + 1) | combo->attributes;
 			rescind_colors = FALSE;
+		} else if (!rescind_colors) {
+			/* No nanorc set a color for this element, so use a colorful
+			 * compiled-in default: this makes nano's interface colored out
+			 * of the box, without any rc files.  NO_COLOR stays honored,
+			 * as rescind_colors gates this whole branch. */
+			static const struct { short fg, bg; int attr; }
+					fallback[NUMBER_OF_ELEMENTS] = {
+				[TITLE_BAR]     = {COLOR_WHITE,  COLOR_BLUE,    A_BOLD},
+				[LINE_NUMBER]   = {COLOR_YELLOW, THE_DEFAULT,   A_NORMAL},
+				[GUIDE_STRIPE]  = {THE_DEFAULT,  THE_DEFAULT,   A_REVERSE},
+				[SCROLL_BAR]    = {COLOR_GREEN,  THE_DEFAULT,   A_NORMAL},
+				[SELECTED_TEXT] = {COLOR_WHITE,  COLOR_MAGENTA, A_NORMAL},
+				[SPOTLIGHTED]   = {COLOR_BLACK,  COLOR_YELLOW,  A_NORMAL},
+				[MINI_INFOBAR]  = {COLOR_WHITE,  COLOR_BLUE,    A_BOLD},
+				[PROMPT_BAR]    = {COLOR_WHITE,  COLOR_BLUE,    A_BOLD},
+				[STATUS_BAR]    = {COLOR_WHITE,  COLOR_GREEN,   A_BOLD},
+				[ERROR_MESSAGE] = {COLOR_WHITE,  COLOR_RED,     A_BOLD},
+				[KEY_COMBO]     = {COLOR_CYAN,   THE_DEFAULT,   A_BOLD},
+				[FUNCTION_TAG]  = {COLOR_WHITE,  THE_DEFAULT,   A_NORMAL},
+			};
+			short fg = fallback[index].fg;
+			short bg = fallback[index].bg;
+
+			if (!defaults_allowed) {
+				if (fg == THE_DEFAULT)
+					fg = COLOR_WHITE;
+				if (bg == THE_DEFAULT)
+					bg = COLOR_BLACK;
+			}
+			init_pair(index + 1, fg, bg);
+			interface_color_pair[index] = COLOR_PAIR(index + 1) | fallback[index].attr;
 		} else {
 			if (index == FUNCTION_TAG || index == SCROLL_BAR)
 				interface_color_pair[index] = A_NORMAL;
diff --git a/src/files.c b/src/files.c
index 02a1503..0badd86 100644
--- a/src/files.c
+++ b/src/files.c
@@ -465,6 +465,14 @@ bool open_buffer(const char *filename, bool new_one)
 #endif
 	}
 
+#if !defined(NANO_TINY) && defined(_WIN32)
+	/* A brand-new file (descriptor 0 means nothing was read from disk) defaults
+	 * to DOS/CRLF line endings, so that classic Windows tools such as Notepad
+	 * read it correctly.  Files opened from disk keep their detected format. */
+	if (descriptor == 0 && new_one)
+		openfile->fmt = DOS_FILE;
+#endif
+
 	/* For a new buffer, store filename and put cursor at start of buffer. */
 	if (descriptor >= 0 && new_one) {
 		openfile->filename = mallocstrcpy(openfile->filename, realname);
diff --git a/src/nano.c b/src/nano.c
index 60d0556..737b710 100644
--- a/src/nano.c
+++ b/src/nano.c
@@ -1873,6 +1873,11 @@ int main(int argc, char **argv)
 	/* Set a sensible default, different from what Pico does. */
 	SET(NO_WRAP);
 
+#ifdef ENABLE_LINENUMBERS
+	/* Show line numbers by default (override with "unset linenumbers"). */
+	SET(LINE_NUMBERS);
+#endif
+
 	/* If the executable's name starts with 'r', activate restricted mode. */
 	if (*(tail(argv[0])) == 'r')
 		SET(RESTRICTED);
diff --git a/src/rcfile.c b/src/rcfile.c
index f3cb137..06cc8fb 100644
--- a/src/rcfile.c
+++ b/src/rcfile.c
@@ -1733,26 +1733,49 @@ void do_rcfiles(void)
 		if (is_good_file(nanorc))
 			parse_one_nanorc();
 	} else {
-		const char *xdgconfdir;
-
-		/* First process the system-wide nanorc, if it exists and is suitable. */
-		const char* allusers = getenv("ALLUSERSPROFILE");
-		if(!allusers)
-			allusers = "C:/Windows";
-		if (have_nanorc(allusers, "/nanorc"))
-			parse_one_nanorc();
-
-		get_homedir();
-		xdgconfdir = getenv("XDG_CONFIG_HOME");
+		bool used_exe_rc = FALSE;
+
+		/* A .nanorc sitting next to nano.exe takes precedence over every other
+		 * location, so nano works as a portable app: drop a .nanorc beside the
+		 * executable and it is used exclusively. */
+		char exedir[PATH_MAX];
+		DWORD exelen = GetModuleFileNameA(NULL, exedir, sizeof(exedir));
+
+		if (exelen > 0 && exelen < sizeof(exedir)) {
+			char *sep = strrchr(exedir, '\\');
+			if (sep == NULL)
+				sep = strrchr(exedir, '/');
+			if (sep != NULL) {
+				*sep = '\0';
+				if (have_nanorc(exedir, "/.nanorc")) {
+					parse_one_nanorc();
+					used_exe_rc = TRUE;
+				}
+			}
+		}
 
-		/* Now try to find a nanorc file in the user's home directory or in the
-		 * XDG configuration directories, and process the first one found. */
-		if (have_nanorc(homedir, "/" HOME_RC_NAME) ||
-					have_nanorc(xdgconfdir, "/nano/" RCFILE_NAME) ||
-					have_nanorc(homedir, "/.config/nano/" RCFILE_NAME))
-			parse_one_nanorc();
-		else if (homedir == NULL && xdgconfdir == NULL)
-			jot_error(N_("I can't find my home directory!  Wah!"));
+		if (!used_exe_rc) {
+			const char *xdgconfdir;
+
+			/* First process the system-wide nanorc, if it exists and is suitable. */
+			const char* allusers = getenv("ALLUSERSPROFILE");
+			if(!allusers)
+				allusers = "C:/Windows";
+			if (have_nanorc(allusers, "/nanorc"))
+				parse_one_nanorc();
+
+			get_homedir();
+			xdgconfdir = getenv("XDG_CONFIG_HOME");
+
+			/* Now try to find a nanorc file in the user's home directory or in the
+			 * XDG configuration directories, and process the first one found. */
+			if (have_nanorc(homedir, "/" HOME_RC_NAME) ||
+						have_nanorc(xdgconfdir, "/nano/" RCFILE_NAME) ||
+						have_nanorc(homedir, "/.config/nano/" RCFILE_NAME))
+				parse_one_nanorc();
+			else if (homedir == NULL && xdgconfdir == NULL)
+				jot_error(N_("I can't find my home directory!  Wah!"));
+		}
 	}
 
 	check_vitals_mapped();
diff --git a/syntax/c.nanorc b/syntax/c.nanorc
index 905587c..9c759d0 100644
--- a/syntax/c.nanorc
+++ b/syntax/c.nanorc
@@ -5,46 +5,48 @@ header "-\*-.*\<C(\+\+)?((;|[[:blank:]]).*)?-\*-"
 magic "^(C|C\+\+) (source|program)"
 comment "//"
 
-# Constants.
-color brightred "\<[[:upper:]_][[:upper:][:digit:]_]*\>"
-# Labels.
-color brightmagenta "^[[:blank:]]*[[:alpha:]_][[:alnum:]_]*:[[:blank:]]*$"
-color normal ":[[:blank:]]*$"
-
-# Types and related keywords.
-color green "\<(bool|char|double|enum|float|int|short|(un)?signed|struct|union|void|((u_?)?int(8|16|32|64)|[[:lower:]][[:lower:]_]*)_t)\>"
-color green "\<(align(as|of)|auto|const(eval|expr|init)?|extern|inline|register|restrict|sizeof|static(_assert)?|thread_local|typedef|typeof(_unqual)?|volatile)\>"
-color green "\<(_(Align(as|of)|Atomic|BitInt|Bool|Complex|Decimal(32|64|128)|Generic|Imaginary|Noreturn|Static_assert|Thread_local))\>"
-color green "\<(class|explicit|final|friend|mutable|namespace|override|private|protected|public|template|this|typename|using|virtual)\>"
-color green "\<(char(8|16|32)_t|wchar_t|(const|dynamic|reinterpret|static)_cast|decltype|export|import|module|noexcept|requires|typeid)\>"
-
-# Flow control.
-color brightyellow "\<(if|else|for|while|do|switch|case|default)\>"
-color brightyellow "\<(try|throw|catch|operator|new|delete)\>"
-color magenta "\<(break|continue|goto|(co_)?return)\>"
-
-# Single-quoted stuff (characters, backslash escapes, hex and octal byte codes).
-color brightmagenta "'([^'\]|\\(["'\abfnrtv]|x[[:xdigit:]]{1,2}|[0-3]?[0-7]{1,2}))'"
-
-# Hexadecimal, binary, and boolean values.
-color pink "\<(0[Xx][[:xdigit:]]['[:xdigit:]]*|0[Bb][01]['01]*|true|false|nullptr)\>"
-
-# GCC builtins.
-color cyan "__attribute__[[:blank:]]*\(\([^)]*\)\)|__(aligned|asm|builtin|hidden|inline|packed|restrict|section|typeof|weak)__"
-
-# Strings and names of included files.
-color brightyellow ""([^"]|\\")*"|#[[:blank:]]*include[[:blank:]]*<[^>]+>"
+# Macros.
+color brightred "\<[A-Z_][0-9A-Z_]+\>"
+
+# Keywords.
+color green "\<(float|double|bool|char|int|short|long|sizeof|typeid|enum|void|auto|static|register|const|volatile|struct|union|typedef|extern|(un)?signed|inline)\>"
+color green "\<(class|namespace|template|public|protected|private|typename|friend|virtual|noexcept|using|mutable|explicit|export|(wchar|char(8|16|32))_t)\>"
+color green "\<(align(as|of)|decltype|constexpr|consteval|thread_local|restrict|_Complex|_Bool|_Imaginary|_Atomic|_Thread_local|_Noreturn|_Align(as|of))\>"
+color green "\<(operator|new|delete|(static|dynamic|const|reinterpret)_cast|static_assert|_Static_assert)\>"
+color brightyellow "\<(for|if|while|do|else|case|default|switch|try|catch)\>"
+color brightmagenta "\<(goto|continue|break|return|throw)\>"
+color yellow "\<(true|false|this|nullptr|__func__)\>"
+
+# Special identifiers.
+color red "\<([[:lower:]][[:lower:]_]*|s?size|ptrdiff|u?int((_(fast|least))?(8|16|32|64)|ptr|max))_t\>"
+color red "\<(std(in|out|err)?|override|final|assert|errno)\>"
+
+# Operators and punctuators.
+color brightcyan "\<(defined|_Pragma|__has_include|_Generic)\>"
+color cyan "[].+*/%=@&|!^~?:,;(){}<>[-]"
+color cyan "\<((and|or|xor|not)(_eq)?|bit(and|or)|compl)\>"
+
+# Literals.
+color yellow "'([^'\]|(\\["'abefnrtv\\]))'" "'\\(([0-3]?[0-7]{1,2}))'" "'\\x[0-9A-Fa-f]{1,2}'"
+color yellow ""(\\.|[^\\"])*?""
+icolor yellow "\<[0-9]+(\.[0-9]*)?(e[+-]?[0-9]+)?(ul{0,2}|l{1,2}u?|f)?\>"
+icolor yellow "\<0x[0-9a-f]+(\.[0-9a-f]*)?(p[+-]?[0-9]+)?(ul{0,2}|l{1,2}u?|f)?\>"
+icolor yellow "\<0b[01]+(ul{0,2}|l{1,2}u?)?\>"
 
 # Preprocessor directives.
-color brightcyan start="^[[:blank:]]*#[[:blank:]]*((el)?if(n?def)?|error|pragma|warning)\>" end="(\`|[^\])$"
-color brightcyan "^[[:blank:]]*#[[:blank:]]*((define|else|embed|endif|include(_next)?|line|undef)\>|$)"
+color brightgreen "^[[:space:]]*#[[:space:]]*include(_next)?[[:space:]]+((<[^>]*>)|("[^"]*"))"
+color brightcyan start="^[[:space:]]*#[[:space:]]*(if(n?def)?|elif|define|undef|warning|error|pragma)\>" end="(\`|[^\\])$"
+color brightcyan "^[[:space:]]*#[[:space:]]*(else|endif|include(_next)?)?\>"
+
+# GCC builtins.
+###color cyan "__attribute__[[:space:]]*\(\([^)]*\)\)" "__(aligned|asm|builtin|hidden|inline|packed|restrict|section|typeof|weak)__"
 
 # Comments.
 color brightblue "//[^"]*$|(^|[[:blank:]])//.*"
 color brightblue start="/\*" end="\*/"
 
 # Reminders.
-color brightwhite,yellow "\<(FIXME|TODO|XXX)\>"
+color red,yellow "\<(FIXME|TODO|XXX)\>"
 
 # Trailing whitespace.
 color ,green "[[:space:]]+$"
