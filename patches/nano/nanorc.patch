# A .nanorc next to nano is used exclusively, overriding all other
# locations, so nano can run as a portable app.

diff --git a/src/rcfile.c b/src/rcfile.c
index 59d932ae..7031ca05 100644
--- a/src/rcfile.c
+++ b/src/rcfile.c
@@ -1733,4 +1733,41 @@ void do_rcfiles(void)
 			parse_one_nanorc();
 	} else {
+		/* A .nanorc next to the executable takes precedence over every other
+		 * location, so nano can run as a portable app: drop a .nanorc beside the
+		 * binary and it is used exclusively. */
+		char exedir[PATH_MAX];
+		int exelen = 0;
+#ifdef _WIN32
+		exelen = (int)GetModuleFileNameA(NULL, exedir, sizeof(exedir));
+		if (exelen >= (int)sizeof(exedir))
+			exelen = 0;
+#elif defined(__linux__)
+		{
+			ssize_t rl = readlink("/proc/self/exe", exedir, sizeof(exedir) - 1);
+			if (rl > 0) {
+				exedir[rl] = '\0';
+				exelen = (int)rl;
+			}
+		}
+#endif
+		if (exelen > 0) {
+			char *sep = strrchr(exedir, '/');
+#ifdef _WIN32
+			char *bslash = strrchr(exedir, '\\');
+			if (bslash != NULL && (sep == NULL || bslash > sep))
+				sep = bslash;
+#endif
+			if (sep != NULL) {
+				*sep = '\0';
+				if (have_nanorc(exedir, "/.nanorc")) {
+					parse_one_nanorc();
+					check_vitals_mapped();
+					free(nanorc);
+					nanorc = NULL;
+					return;
+				}
+			}
+		}
+
 		const char *xdgconfdir;
 
