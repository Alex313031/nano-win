# Compile in a Windows resource (icon + version info) via windres: adds src/nano.rc
# and the src/Makefile.am windres rule. nano.rc #includes version.h (supplied by
# version-info.patch); the binary nano.ico is copied into src/ by build_nano.sh.

diff --git a/src/Makefile.am b/src/Makefile.am
index a678e29..3bb7cff 100644
--- a/src/Makefile.am
+++ b/src/Makefile.am
@@ -1,7 +1,7 @@
 AM_CPPFLAGS = -DLOCALEDIR=\"$(localedir)\" -DSYSCONFDIR=\"$(sysconfdir)\" \
 	-I$(top_builddir)/lib -I$(top_srcdir)/lib
 
-CLEANFILES = revision.h
+CLEANFILES = revision.h nano_rc.$(OBJEXT)
 
 if BUILDING_FROM_GIT
 SOMETHING = "REVISION \"`git describe --tags 2>/dev/null`\""
@@ -43,7 +43,13 @@ nano_SOURCES = \
 		winio.c
 
 nano_LDADD = $(top_builddir)/lib/libgnu.a @LIBINTL@ \
-		$(GETRANDOM_LIB) $(CLOCK_TIME_LIB) $(LIBTHREAD)
+		$(GETRANDOM_LIB) $(CLOCK_TIME_LIB) $(LIBTHREAD) \
+		nano_rc.$(OBJEXT)
+
+# Windows resource: application icon + version info, compiled with windres.
+# nano.rc is added by this patch; the binary nano.ico is copied into src/ by build_nano.sh.
+nano_rc.$(OBJEXT): $(srcdir)/nano.rc $(srcdir)/nano.ico
+	@host_alias@-windres -I$(srcdir) -O coff -i $(srcdir)/nano.rc -o $@
 
 install-exec-hook:
 	cd $(DESTDIR)$(bindir) && rm -f rnano && $(LN_S) nano rnano
diff --git a/src/nano.rc b/src/nano.rc
new file mode 100644
index 0000000..5b36b30
--- /dev/null
+++ b/src/nano.rc
@@ -0,0 +1,57 @@
+// Copyright (c) 2026 Alex313031
+
+// Nano win32 resource script file
+
+#define APSTUDIO_READONLY_SYMBOLS
+
+#define APSTUDIO_HIDDEN_SYMBOLS
+#include <winver.h>
+#undef APSTUDIO_HIDDEN_SYMBOLS
+
+#undef APSTUDIO_READONLY_SYMBOLS
+
+// Nano version numbers + strings. version.h guards its C declarations behind
+// RC_INVOKED, so here only the version macros are exposed. Provided by version.c
+// / version.h (added by version-info.patch, later in the series).
+#include "version.h"
+
+// Embed icon
+101 ICON "nano.ico"
+
+#ifdef _DEBUG
+#define NANO_FILEFLAGS VS_FF_DEBUG
+#else
+#define NANO_FILEFLAGS 0x0L
+#endif
+
+VS_VERSION_INFO VERSIONINFO
+ FILEVERSION    NANO_VER_COMMA
+ PRODUCTVERSION NANO_VER_COMMA
+ FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
+ FILEFLAGS      NANO_FILEFLAGS
+ FILEOS         VOS_NT_WINDOWS32
+ FILETYPE       VFT_APP
+ FILESUBTYPE    VFT2_UNKNOWN
+BEGIN
+    BLOCK "StringFileInfo"
+    BEGIN
+        BLOCK "040904B0" // 0x0409 = U.S. English, 0x04B0 = 1200 = Unicode.
+        BEGIN
+            VALUE "CompanyName",      L"Alex313031"
+            VALUE "FileDescription",  L"Nano text editor"
+            VALUE "FileVersion",      NANO_VER_STR
+            VALUE "InternalName",     L"nano"
+            VALUE "LegalCopyright",   L"\251 2026 Alex313031"
+            VALUE "LegalTrademarks",  L"GPL-3 License"
+            VALUE "OriginalFilename", L"nano.exe"
+            VALUE "ProductName",      L"Nano"
+            VALUE "ProductVersion",   NANO_VER_STR
+            VALUE "Comments",         L"https://github.com/Alex313031/nano"
+        END
+    END
+    BLOCK "VarFileInfo"
+    BEGIN
+        // Must match the language/codepage of the StringFileInfo block above.
+        VALUE "Translation", 0x409, 1200
+    END
+END
