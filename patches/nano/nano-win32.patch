+/* GetConsoleWindow() first appeared in Windows 2000; on Windows NT 4.0 it is
+ * absent from kernel32.dll, so importing it statically stops nano from loading
+ * there.  Resolve it dynamically, and when it is missing fall back to an NT4-safe
+ * console check.  Callers only test the result against NULL, so a non-NULL
+ * sentinel is fine when there is no window handle to return. */
+void *GetConsoleWindowEx(void)
+{
+	typedef HWND (WINAPI *GetConsoleWindow_fn)(void);
+	static GetConsoleWindow_fn p_GetConsoleWindow = NULL;
+	static BOOL resolved = FALSE;
+
+	if (!resolved) {
+		HMODULE k32 = GetModuleHandleA("kernel32.dll");
+		if (k32 != NULL)
+			p_GetConsoleWindow =
+				(GetConsoleWindow_fn)GetProcAddress(k32, "GetConsoleWindow");
+		resolved = TRUE;
+	}
+
+	if (p_GetConsoleWindow != NULL)
+		return (void *)p_GetConsoleWindow();
+
+	/* NT 4.0 fallback: no console-window handle exists, so report a non-NULL
+	 * sentinel when a console is attached (either standard handle is one). */
+	{
+		DWORD mode;
+
+		if (GetConsoleMode(GetStdHandle(STD_INPUT_HANDLE), &mode) ||
+				GetConsoleMode(GetStdHandle(STD_OUTPUT_HANDLE), &mode))
+			return (void *)(size_t)1;
+
+		return NULL;
+	}
+}
+
+/* IsUserAnAdmin() lives in shell32.dll v4.71+ (shipped with IE4); base Windows NT
+ * 4.0 has an older shell32 without it, so a static import would break loading there.
+ * Resolve it dynamically, and fall back to an NT4-safe token-group membership check
+ * (CheckTokenMembership is Windows 2000+, so walk the token's groups by hand). */
+int IsUserAnAdminEx(void)
+{
+	typedef BOOL (WINAPI *IsUserAnAdmin_fn)(void);
+	static IsUserAnAdmin_fn p_IsUserAnAdmin = NULL;
+	static BOOL resolved = FALSE;
+
+	if (!resolved) {
+		HMODULE shell32 = LoadLibraryA("shell32.dll");
+		if (shell32 != NULL)
+			p_IsUserAnAdmin =
+				(IsUserAnAdmin_fn)GetProcAddress(shell32, "IsUserAnAdmin");
+		resolved = TRUE;
+	}
+
+	if (p_IsUserAnAdmin != NULL)
+		return p_IsUserAnAdmin();
+
+	{
+		SID_IDENTIFIER_AUTHORITY nt_authority = SECURITY_NT_AUTHORITY;
+		HANDLE token = NULL;
+		TOKEN_GROUPS *groups = NULL;
+		PSID admins = NULL;
+		DWORD len = 0, i;
+		BOOL is_admin = FALSE;
+
+		if (!OpenProcessToken(GetCurrentProcess(), TOKEN_QUERY, &token))
+			return FALSE;
+
+		GetTokenInformation(token, TokenGroups, NULL, 0, &len);
+		if (len > 0)
+			groups = (TOKEN_GROUPS *)malloc(len);
+
+		if (groups != NULL &&
+				GetTokenInformation(token, TokenGroups, groups, len, &len) &&
+				AllocateAndInitializeSid(&nt_authority, 2, SECURITY_BUILTIN_DOMAIN_RID,
+					DOMAIN_ALIAS_RID_ADMINS, 0, 0, 0, 0, 0, 0, &admins)) {
+			for (i = 0; i < groups->GroupCount; i++)
+				if (EqualSid(groups->Groups[i].Sid, admins)) {
+					is_admin = TRUE;
+					break;
+				}
+			FreeSid(admins);
+		}
+
+		free(groups);
+		CloseHandle(token);
+		return is_admin;
+	}
+}
+
+/* PathIsRelativeA() lives in shlwapi.dll, which base Windows NT 4.0 lacks (it came
+ * with IE4). Resolve it dynamically, and fall back to the same rule it implements:
+ * a path is relative unless it starts with a separator or is drive-qualified. */
+int PathIsRelativeEx(const char *path)
+{
+	typedef BOOL (WINAPI *PathIsRelativeA_fn)(LPCSTR);
+	static PathIsRelativeA_fn p_PathIsRelativeA = NULL;
+	static BOOL resolved = FALSE;
+
+	if (!resolved) {
+		HMODULE shlwapi = LoadLibraryA("shlwapi.dll");
+		if (shlwapi != NULL)
+			p_PathIsRelativeA =
+				(PathIsRelativeA_fn)GetProcAddress(shlwapi, "PathIsRelativeA");
+		resolved = TRUE;
+	}
+
+	if (p_PathIsRelativeA != NULL)
+		return p_PathIsRelativeA(path);
+
+	if (path == NULL || path[0] == '\0')
+		return TRUE;
+	if (path[0] == '\\' || path[0] == '/')
+		return FALSE;
+	if (path[1] == ':')
+		return FALSE;
+	return TRUE;
+}
