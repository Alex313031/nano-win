+#ifndef NANO_WIN32_H_
+#define NANO_WIN32_H_
+
+// Header to be used in place of <windows.h> for all Nano Win32 support code
+// to ensure consistency and legacy Windows support.
+
+#if defined(_WIN32) && !defined(__linux__)
+
+#ifndef UNICODE
+ #define UNICODE
+#endif
+
+#ifndef _UNICODE
+ #define _UNICODE
+#endif
+
+#include "winsdkver.h"
+
+#ifndef _WIN32_WINNT
+ #define _WIN32_WINNT 0x0400 // Windows NT 4
+#endif
+
+#ifndef WINVER
+ #define WINVER 0x0400 // Same as _WIN32_WINNT above
+#endif
+
+#ifndef _WIN32_IE
+ #define _WIN32_IE 0x0400 // Minimum Internet Explorer version for common controls
+#endif
+
+#include "sdkddkver.h"
+
+#ifndef WIN32_LEAN_AND_MEAN
+ #define WIN32_LEAN_AND_MEAN 1
+#endif
+
+#include <windows.h>
+#include <shlobj.h>
+#include <shlwapi.h>
+#include <tchar.h>
+
+#endif // _WIN32 && !__linux__
+
+#endif // NANO_WIN32_H_
