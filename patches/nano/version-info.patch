diff --git a/src/version.c b/src/version.c
new file mode 100644
index 0000000..7e5147a
--- /dev/null
+++ b/src/version.c
@@ -0,0 +1,112 @@
+// Version/host-info helpers for the Windows build. Declared in version.h.
+
+#ifdef HAVE_CONFIG_H
+#include <config.h>
+#endif
+
+#if defined(_WIN32)
+# include "win32.h"   // windows.h + legacy-Windows version guards
+#elif defined(__linux__)
+# include <sys/utsname.h>
+#endif
+
+#include <stdio.h>   // snprintf
+
+#include "version.h"
+
+// nano's version string. Prefer config.h's PACKAGE_STRING ("GNU nano 9.1",
+// straight from configure.ac's AC_INIT) so the reported version always matches
+// the build; fall back to the numeric macros in version.h if config.h is absent.
+const char *nano_get_version(void)
+{
+#ifdef PACKAGE_STRING
+	return PACKAGE_STRING;
+#else
+	return "GNU nano " NANO_VER_STR;
+#endif
+}
+
+// Host OS version as "Windows <major>.<minor>.<build>" (or uname(2)'s string on
+// Linux). On Windows the true NT version is resolved without being fooled by the
+// compatibility shims -- see the per-tier notes in the function body. Cached in a
+// static buffer (nano's Win32 code is single-threaded).
+const char *nano_get_os_version(void)
+{
+	static char buf[256];  // large enough for uname(2)'s worst case, too
+
+	if (buf[0] == '\0') {
+#if defined(_WIN32)
+		/* Report the *true* NT kernel version. Two Windows mechanisms lie about
+		 * it: since 8.1, GetVersionEx reports 6.2 (Windows 8) for apps without a
+		 * compatibility manifest; and since XP, the "compatibility mode" tab can
+		 * shim the version an app sees. Resolve dynamically (older targets lack
+		 * the newer calls) and pick, per OS, the API that defeats every lie that
+		 * applies there:
+		 *   RtlGetNtVersionNumbers -- XP+, undocumented. Reads ntdll's baked-in
+		 *       build number, so it ignores BOTH the manifest lie and the compat
+		 *       tab. Preferred whenever present.
+		 *   RtlGetVersion          -- 2000+, documented. Defeats the manifest lie,
+		 *       but the compat tab can still shim it -- so it is only reached on
+		 *       2000, which has neither a compat tab nor RtlGetNtVersionNumbers by
+		 *       name (only by ordinal), and where it is therefore exact.
+		 *   GetVersionExW          -- NT 4.0 fallback; predates both shims, so it
+		 *       cannot lie there. */
+		typedef void (WINAPI *RtlGetNtVersionNumbers_fn)(DWORD *, DWORD *, DWORD *);
+		typedef LONG (WINAPI *RtlGetVersion_fn)(OSVERSIONINFOW *);
+		RtlGetNtVersionNumbers_fn p_RtlGetNtVersionNumbers = NULL;
+		RtlGetVersion_fn p_RtlGetVersion = NULL;
+		HMODULE ntdll;
+		DWORD major = 0, minor = 0, build = 0;
+		BOOL got = FALSE;
+
+		/* ntdll.dll is always mapped, so GetModuleHandle suffices. */
+		ntdll = GetModuleHandleA("ntdll.dll");
+		if (ntdll != NULL) {
+			p_RtlGetNtVersionNumbers = (RtlGetNtVersionNumbers_fn)
+				GetProcAddress(ntdll, "RtlGetNtVersionNumbers");
+			p_RtlGetVersion = (RtlGetVersion_fn)
+				GetProcAddress(ntdll, "RtlGetVersion");
+		}
+
+		if (p_RtlGetNtVersionNumbers != NULL) {
+			p_RtlGetNtVersionNumbers(&major, &minor, &build);
+			build &= 0x0FFFFFFF;   /* top nibble is a build-type flag */
+			got = TRUE;
+		} else {
+			OSVERSIONINFOW ovi;
+
+			SecureZeroMemory(&ovi, sizeof ovi);
+			ovi.dwOSVersionInfoSize = sizeof ovi;
+
+			if (p_RtlGetVersion != NULL)
+				got = (p_RtlGetVersion(&ovi) == 0);   /* 0 == STATUS_SUCCESS */
+			else
+				got = GetVersionExW(&ovi);
+
+			if (got) {
+				major = ovi.dwMajorVersion;
+				minor = ovi.dwMinorVersion;
+				build = ovi.dwBuildNumber;
+			}
+		}
+
+		if (got)
+			snprintf(buf, sizeof buf, "Windows %lu.%lu.%lu",
+					(unsigned long)major, (unsigned long)minor,
+					(unsigned long)build);
+		else
+			snprintf(buf, sizeof buf, "Windows (unknown)");
+#elif defined(__linux__)
+		struct utsname u;
+
+		if (uname(&u) == 0)
+			snprintf(buf, sizeof buf, "%s %s (%s)", u.sysname, u.release, u.machine);
+		else
+			snprintf(buf, sizeof buf, "Unknown Linux");
+#else
+		snprintf(buf, sizeof buf, "Unknown OS");
+#endif
+	}
+
+	return buf;
+}
diff --git a/src/version.h b/src/version.h
new file mode 100644
index 0000000..98001c4
--- /dev/null
+++ b/src/version.h
@@ -0,0 +1,45 @@
+#ifndef NANO_VERSION_H_
+#define NANO_VERSION_H_
+
+// Single source of truth for the version baked into nano.exe's Windows resource
+// (FILEVERSION / VERSIONINFO strings, see nano.rc) and returned by the getters
+// below. Bump these to re-version the build; keep MAJOR.MINOR in step with nano's
+// own version (configure.ac AC_INIT -> config.h VERSION / PACKAGE_STRING).
+#define NANO_MAJOR  9
+#define NANO_MINOR  1
+#define NANO_PATCH  7
+#define NANO_BUILD  0
+
+// Stringize helpers (two levels so the numeric macros above expand first).
+#ifndef NANO_STR_
+#define NANO_STR_(x)  #x
+#define NANO_STRINGIZE(x)  NANO_STR_(x)
+#endif
+
+// Comma-separated form for the .rc's FILEVERSION / PRODUCTVERSION fields.
+#define NANO_VER_COMMA  NANO_MAJOR, NANO_MINOR, NANO_PATCH, NANO_BUILD
+
+// Dotted "major.minor.patch" string for the VERSIONINFO StringFileInfo values.
+// windres stores VERSIONINFO strings as UTF-16 regardless, so no L"" prefix here.
+#define NANO_VER_STR \
+	NANO_STRINGIZE(NANO_MAJOR) "." NANO_STRINGIZE(NANO_MINOR) "." NANO_STRINGIZE(NANO_PATCH)
+
+#ifndef RC_INVOKED
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+// Human-readable nano version, e.g. "GNU nano, version 9.1" (from config.h).
+const char *nano_get_version(void);
+
+// Host OS version, e.g. "Windows 5.1.2600" or "Linux 6.17.0-35-generic (x86_64)" (queried at runtime).
+const char *nano_get_os_version(void);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif // !RC_INVOKED
+
+#endif // NANO_VERSION_H_
